{
  // ============================================================
  // Battery Dot Overlay
  // Конфигурация минималистичного VR overlay-индикатора батареи.
  //
  // Важно:
  // - файл поддерживает комментарии;
  // - после изменения файла перезапустите приложение;
  // - проценты указываются в диапазоне 0..100;
  // - прозрачность указывается в диапазоне 0.0..1.0.
  // ============================================================

  "overlay": {
    // Уникальный ключ overlay в OpenVR/SteamVR.
    // Если хотите запускать независимые копии с разными точками, у каждой
    // копии должен быть свой overlay_key.
    "overlay_key": "com.vrapp.utility.batterydot",

    // Имя overlay, которое видно в OpenVR/SteamVR.
    "overlay_name": "Battery Dot Overlay",

    // Физический размер точки в VR-пространстве, в метрах.
    "width_in_meters": 0.028,

    // Расстояние от глаз до overlay, в метрах.
    "distance_meters": 0.24,

    // Смещение точки по горизонтали.
    // Положительное значение двигает точку вправо.
    "horizontal_offset_meters": 0.095,

    // Смещение точки по вертикали.
    // Положительное значение двигает точку вверх.
    "vertical_offset_meters": 0.065,

    // Порядок отрисовки overlay.
    "sort_order": 120
  },

  "visual": {
    // Цвет точки в формате #RRGGBB.
    "color_hex": "#FFD54A",

    // Прозрачность точки.
    // 0.0 = полностью прозрачная, 1.0 = полностью непрозрачная.
    "opacity": 0.55,

    // Размер внутренней текстуры точки в пикселях.
    "texture_size_pixels": 128,

    // Относительный размер круга внутри текстуры.
    "circle_fill_ratio": 0.62,

    // Мягкость края круга в пикселях.
    "edge_feather_pixels": 2.0
  },

  "behavior": {
    // Частота мигания в герцах.
    // 1.0 = одно мигание в секунду.
    // 0.0 = не мигать, а просто держать точку видимой.
    "blink_frequency_hz": 1.0,

    // Порог заряда, ниже которого точка может включиться.
    // 100.0 -> предупреждать при любом заряде ниже 100%;
    // 90.0  -> предупреждать только ниже 90%.
    "blink_below_percent": 100.0,

    // Учитывать ли состояние зарядки шлема.
    //
    // true:
    // - точка мигает только если заряд ниже порога и шлем не заряжается;
    // - если статус зарядки определить не удалось, приложение работает по старой
    //   логике и ориентируется только на процент батареи.
    //
    // false:
    // - полностью старое поведение без учёта зарядки.
    "blink_only_when_not_charging": true,

    // Как часто опрашивать батарею и статус зарядки, в миллисекундах.
    "battery_poll_interval_ms": 1000,

    // Как часто писать статус в консоль и лог-файл, в секундах.
    "status_log_interval_seconds": 15
  },

  "battery": {
    // Принудительный индекс tracked device для OpenVR.
    // -1 = автоматический выбор.
    "preferred_device_index": -1,

    // Печатать диагностику источников батареи при старте приложения.
    "log_diagnostics_on_startup": true,

    // Печатать расширенную диагностику, если батарея не была получена.
    "log_diagnostics_when_unavailable": true,

    // Включить ADB fallback.
    // Это основной универсальный fallback для Android-шлемов, если OpenVR
    // не отдаёт батарею HMD или не обновляет состояние зарядки.
    "enable_adb_fallback": true,

    // Пользовательский путь к adb.exe или к папке, где лежит adb.exe.
    // Пустая строка = искать автоматически:
    // - %LOCALAPPDATA%\\Android\\Sdk\\platform-tools\\adb.exe
    // - ANDROID_SDK_ROOT / ANDROID_HOME
    // - PATH
    "adb_path": "",

    // Серийный номер adb-устройства, если подключено несколько Android-устройств.
    // Пустая строка = использовать поведение adb по умолчанию.
    "adb_device_serial": "",

    // Таймаут ADB-команды в миллисекундах.
    "adb_command_timeout_ms": 2000,

    // Разрешить запасной fallback через логи PICO Connect.
    // Используется только если OpenVR и ADB не помогли.
    "enable_pico_connect_log_fallback": true,

    // Пользовательский путь к папке логов PICO Connect.
    // Пустая строка = путь по умолчанию из AppData.
    "pico_connect_logs_path": "",

    // Максимальный возраст событий батареи и питания из PICO Connect, в секундах.
    "pico_connect_event_max_age_seconds": 120,

    // Сколько байт читать с конца логов PICO Connect при поиске свежих событий.
    "pico_connect_log_tail_bytes": 262144
  },

  "runtime": {
    // Внутренняя задержка главного цикла приложения, в миллисекундах.
    "loop_delay_ms": 50,

    // Включить ли логирование в файл.
    "enable_file_logging": true,

    // Папка для логов.
    // Можно указать относительный путь, тогда он считается от папки exe.
    "logs_directory": "logs",

    // Сколько последних лог-файлов хранить.
    "max_log_files": 10,

    // Разрешать только одну копию приложения с одним и тем же overlay_key.
    // Это защищает от повторного запуска и ошибки KeyInUse.
    "enforce_single_instance": true
  }
}
