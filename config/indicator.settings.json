{
  // ============================================================
  // Battery Dot Overlay
  // Конфигурация индикатора батареи для VR overlay.
  //
  // Важно:
  // - файл поддерживает комментарии;
  // - после изменения файла перезапустите приложение;
  // - проценты указываются в диапазоне 0..100;
  // - прозрачность указывается в диапазоне 0.0..1.0.
  // ============================================================

  "overlay": {
    // Уникальный ключ overlay в OpenVR/SteamVR.
    // Если запускать сразу несколько копий приложения, у каждой нужен свой ключ.
    "overlay_key": "com.vrapp.utility.batterydot",

    // Имя overlay, которое видно в системе OpenVR/SteamVR.
    "overlay_name": "Battery Dot Overlay",

    // Физический размер точки в VR-пространстве, в метрах.
    // Меньше значение -> точка визуально меньше.
    "width_in_meters": 0.028,

    // Расстояние от глаз до overlay, в метрах.
    // Меньше значение -> точка кажется ближе к глазам.
    "distance_meters": 0.24,

    // Смещение точки по горизонтали, в метрах.
    // Положительное значение двигает точку вправо.
    // Отрицательное значение двигает точку влево.
    "horizontal_offset_meters": 0.095,

    // Смещение точки по вертикали, в метрах.
    // Положительное значение двигает точку вверх.
    // Отрицательное значение двигает точку вниз.
    "vertical_offset_meters": 0.065,

    // Порядок отрисовки overlay.
    // Обычно менять не нужно.
    // Большее значение может рисоваться поверх других overlay.
    "sort_order": 120
  },

  "visual": {
    // Цвет точки в формате #RRGGBB.
    // Текущий цвет: мягкий жёлтый.
    "color_hex": "#FFD54A",

    // Прозрачность точки.
    // 0.0 = полностью прозрачная, 1.0 = полностью непрозрачная.
    "opacity": 0.55,

    // Размер внутренней текстуры точки в пикселях.
    // Большее значение может сделать край чуть аккуратнее,
    // но для такой простой точки обычно это не критично.
    "texture_size_pixels": 128,

    // Относительный размер круга внутри прозрачной текстуры.
    // Чем больше значение, тем больше сам круг.
    "circle_fill_ratio": 0.62,

    // Мягкость края круга, в пикселях.
    // Больше значение -> край более плавный.
    "edge_feather_pixels": 2.0
  },

  "behavior": {
    // Частота мигания в герцах.
    // 1.0 = одно мигание в секунду.
    // 2.0 = два мигания в секунду.
    // 0.0 = не мигать, а просто постоянно показывать точку.
    "blink_frequency_hz": 1.0,

    // Порог заряда, ниже которого точка начинает мигать.
    // Пример:
    // 100.0 -> мигать при любом заряде ниже 100%.
    // 90.0  -> мигать только ниже 90%.
    // 25.0  -> мигать только при низком заряде ниже 25%.
    "blink_below_percent": 100.0,

    // Как часто приложение опрашивает уровень батареи, в миллисекундах.
    // 1000 = раз в секунду.
    "battery_poll_interval_ms": 1000,

    // Как часто писать строку статуса в консоль, в секундах.
    // На сам overlay не влияет, только на частоту логов.
    "status_log_interval_seconds": 15
  },

  "battery": {
    // Принудительный индекс устройства OpenVR, если нужно вручную указать,
    // с какого tracked device читать батарею.
    // -1 = автоматический выбор.
    // Обычно менять не нужно.
    "preferred_device_index": -1,

    // Печатать подробную диагностику устройств при старте приложения.
    // true  = выводить список устройств и найденные значения батареи.
    // false = не выводить лишнюю диагностику.
    "log_diagnostics_on_startup": true,

    // Печатать дополнительную диагностику, если заряд не удалось получить.
    // Полезно для поиска проблем с драйвером или runtime.
    "log_diagnostics_when_unavailable": true,

    // Разрешить fallback для PICO Connect.
    // Если OpenVR не отдаёт батарею HMD, приложение попробует прочитать
    // свежие события батареи из локальных логов PICO Connect.
    "enable_pico_connect_log_fallback": true,

    // Пользовательский путь к папке логов PICO Connect.
    // Пустая строка = использовать путь по умолчанию из AppData.
    // Заполняйте только если логи находятся в нестандартном месте.
    "pico_connect_logs_path": "",

    // Максимальный возраст события батареи из PICO Connect, в секундах.
    // Если событие старше этого времени, оно считается устаревшим.
    "pico_connect_event_max_age_seconds": 120,

    // Сколько байт читать с конца лог-файла PICO Connect при поиске
    // свежего значения батареи.
    // Обычно менять не нужно.
    "pico_connect_log_tail_bytes": 262144
  },

  "runtime": {
    // Внутренняя задержка главного цикла приложения, в миллисекундах.
    // Меньше значение = чаще обновление, но для такой задачи обычно
    // стандартного значения достаточно.
    "loop_delay_ms": 50
  }
}
